<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
xmlns:p="http://www.springframework.org/schema/p"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean name="arr1" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <value>11</value>
                <value>22</value>
                <value>33</value>
                <value>44</value>
                <value>11</value>
                <value>44</value>
                <value>33</value>
                <value>66</value>
            </list>
        </constructor-arg>
    </bean>


    <bean name="ss1" class="java.util.HashSet">
        <constructor-arg>
            <set>
                <value>11</value>
                <value>22</value>
                <value>33</value>
                <value>44</value>
                <value>11</value>
                <value>44</value>
                <value>33</value>
                <value>66</value>
            </set>
        </constructor-arg>
    </bean>


    <bean name="mm1" class="java.util.HashMap">
        <constructor-arg>
            <map>
                <entry>
                    <key>
                        <value>사자</value>
                    </key>
                    <value>포유류</value>
                </entry>
                <entry>
                    <key>
                        <value>오타니</value>
                    </key>
                    <value>이도류</value>
                </entry>
                <entry>
                    <key>
                        <value>호랑이</value>
                    </key>
                    <value>포유류</value>
                </entry>
            </map>
        </constructor-arg>
    </bean>

</beans>