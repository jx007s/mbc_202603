<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
xmlns:p="http://www.springframework.org/schema/p"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="bch" class="di_p.Bonche" p:name="삼보컴퓨터" p:price="100" />
    <bean id="mm1" class="di_p.Monitor" p:name="골드스타" p:price="30" />
    <bean id="mm2" class="di_p.Monitor" p:name="SMACO" p:price="20" />
    <bean id="kb" class="di_p.KeyBoard" p:name="한성" p:price="15" />
    <bean id="mo" class="di_p.Mouse" p:name="MXMaster" p:price="9" />


    <bean id="ss" class="di_p.Server" p:name="게이밍서버" autowire="byName"/>

    <bean id="dk" class="di_p.DeskTop" p:name="집에서작업용" autowire="byType"
    p:mm1-ref="mm2" />
    <bean id="nb" class="di_p.NoteBook" p:name="학교에서" autowire="byType" />
    <bean id="tb" class="di_p.Tablet" p:name="기차에서" autowire="byType" />


</beans>