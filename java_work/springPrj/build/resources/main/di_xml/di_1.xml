<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
xmlns:p="http://www.springframework.org/schema/p"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean 등록
    id : bean 등록 이름  , 이것으로 호출 한다
    class : 생성할 인스턴스 의 원형 클래스 (패키지명을 모두 적어야 한다)
    -->
    <bean id="cam2" class="di_p.Camera">
        <!-- propetry :: setter 메소드를 이용하여 멤버변수 값 입력
        name="name"  : setName()   value :  매개변수
        cam2.setName("후방카메라")
        -->
        <property name="name">
            <value>후방카메라</value>
        </property>
        <property name="kind" value="적외선렌즈"/>
        <!--<property name="size" value="작은거"/>  setter 가 있어야 한다 -->
    </bean>

    <bean id="cam3" class="di_p.Camera" p:name="캐논" p:kind="DSLR" />
    <bean id="cam4" class="di_p.Camera" p:name="니콘" p:kind="미러리스" />

    <bean id="mm1" class="di_p.Mic" p:name="노래방마이크" p:price="50" />

    <bean id="hp1" class="di_p.HandPhone" p:name="은하수"
        p:rc-ref="cam4" p:mm-ref="mm1">
        <property name="fc">
            <ref bean="cam3"/>
        </property>
    </bean>
</beans>